# Environment
# Blanket-ignore all .env* files repo-wide; committed defaults are un-ignored below.
.env*
# Root-level example template — always committed
!.env.example
# experience/ committed env defaults (staging + production are NOT secrets — they only set VITE_AUTH_MODE=oidc)
!experience/.env.example
!experience/.env.staging
!experience/.env.production
# Local-dev example file is committed so developers can copy it; the actual local file is ignored
!experience/.env.development.local.example
# Explicit patterns for files that must never be committed (belt-and-suspenders; already covered by .env* above)
experience/.env.local
experience/.env.development.local

# .NET
bin/
obj/
**/bin/**
**/obj/**
**/bin\\Debug/**
**/bin\\Release/**
**/bin*Debug/**
**/bin*Release/**
**/obj*Debug/**
**/obj*Release/**
*.user
*.suo
*.csproj.user
*.csproj.lscache
engine/src/Nebula.Api/out.xml
TestResults/
engine/coverage/
coverage-report/

# Node / React
node_modules/
.pnpm-store/
**/.pnpm-store/
dist/
.next/
.vite/vitest/**
build/
experience/coverage/
playwright-report/
test-results/

# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/
*.egg-info/

# KG workstate (scripts/kg/workstate.py session files)
.kg-state/

# IDE
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/
# Evidence logs are audit artifacts — un-ignore them
!planning-mds/operations/evidence/**/*.log

# Docker
docker-compose.override.yml

# Local document store (LocalFileSystemDocumentRepository). Uploaded customer
# binaries (account/, policy/, submission/, renewal/) and quarantine/ are
# runtime state. configuration/ (taxonomy, retention, Casbin doc roles,
# metadata schemas) and templates/ (shared blank ACORD/proposal/notice forms)
# are baseline assets and ARE tracked.
# Pattern note: ignore direct children only (/*) so git still walks into the
# un-ignored subtrees below.
engine/src/Nebula.Api/data/documents/*
!engine/src/Nebula.Api/data/documents/configuration/
!engine/src/Nebula.Api/data/documents/templates/
engine/src/Nebula.Api/data/documents/configuration/retention-sweeps.jsonl

# Security reports
security-reports/

# QE toolchain artifacts (F0033)
.sonarqube/
.lighthouseci/
experience/.lighthouseci/
experience/pacts/
planning-mds/operations/evidence/f0033/artifacts/

# Test runner output — ephemeral, never commit (repo-wide)
# Raw coverage output (HTML/lcov); the curated coverage-report.md evidence doc is still tracked.
**/test-results/
**/coverage/

# Durable evidence artifacts are committed even when general test/coverage outputs are ignored.
!planning-mds/operations/evidence/runs/**/artifacts/
!planning-mds/operations/evidence/runs/**/artifacts/test-results/
!planning-mds/operations/evidence/runs/**/artifacts/coverage/
!planning-mds/operations/evidence/runs/**/artifacts/security/
!planning-mds/operations/evidence/runs/**/artifacts/diffs/
!planning-mds/operations/evidence/runs/**/artifacts/screenshots/
!planning-mds/operations/evidence/runs/**/artifacts/**/*.txt
!planning-mds/operations/evidence/runs/**/artifacts/**/*.log
!planning-mds/operations/evidence/runs/**/artifacts/**/*.json
!planning-mds/operations/evidence/runs/**/artifacts/**/*.xml
!planning-mds/operations/evidence/runs/**/artifacts/**/*.trx
!planning-mds/operations/evidence/runs/**/artifacts/**/*.sarif
!planning-mds/operations/evidence/runs/**/artifacts/**/*.png

# private plans
_private-plans/**
