{
  "name": "nebula-insurance-crm",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:theme": "node ./scripts/check-theme-semantic-classes.mjs",
    "lint:effects": "node ./scripts/check-no-hardcoded-effects.mjs",
    "test": "vitest run --exclude src/**/*.integration.test.ts --exclude src/**/*.integration.test.tsx --exclude src/**/*.a11y.test.ts --exclude src/**/*.a11y.test.tsx",
    "test:watch": "vitest",
    "test:integration": "node ./scripts/run-vitest-by-pattern.mjs .integration.test.",
    "test:accessibility": "node ./scripts/run-vitest-by-pattern.mjs .a11y.test.",
    "test:coverage": "vitest run --coverage",
    "test:frontend:full": "pnpm lint && pnpm lint:css && pnpm lint:theme && pnpm lint:effects && pnpm build && pnpm test && pnpm test:integration && pnpm test:accessibility && pnpm test:coverage && pnpm test:visual:theme --reporter=line",
    "test:visual:theme": "playwright test tests/visual/theme-smoke.spec.ts",
    "test:visual:theme:update": "playwright test tests/visual/theme-smoke.spec.ts --update-snapshots",
    "test:performance": "lhci autorun --config=./lighthouserc.json",
    "test:contracts": "vitest run --config vitest.contracts.config.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.0",
    "ajv": "8.20.0",
    "ajv-errors": "3.0.0",
    "ajv-formats": "3.0.1",
    "clsx": "^2.1.0",
    "lucide-react": "^0.575.0",
    "oidc-client-ts": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "7.76.1",
    "react-router-dom": "^7.15.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@pact-foundation/pact": "^13.2.0",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@vitest/coverage-v8": "^2.1.9",
    "@types/node": "^25.3.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^26.1.0",
    "msw": "^2.11.3",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.9"
  }
}
