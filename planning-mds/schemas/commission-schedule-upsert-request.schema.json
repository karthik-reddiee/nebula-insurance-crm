{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nebula.local/schemas/commission-schedule-upsert-request.schema.json",
  "title": "CommissionScheduleUpsertRequest",
  "type": "object",
  "required": ["carrierMarketId", "lineOfBusiness", "rateType", "rateValue", "basis", "effectiveFrom"],
  "properties": {
    "carrierMarketId": { "type": "string", "format": "uuid" },
    "lineOfBusiness": { "type": "string", "minLength": 1, "maxLength": 80 },
    "state": { "type": ["string", "null"], "pattern": "^[A-Z]{2}$" },
    "productCode": { "type": ["string", "null"], "maxLength": 80 },
    "rateType": { "type": "string", "enum": ["PercentOfPremium", "FlatAmount"] },
    "rateValue": { "type": "number", "minimum": 0 },
    "basis": { "type": "string", "enum": ["WrittenPremium", "AnnualizedPremium", "ManualBasis"] },
    "effectiveFrom": { "type": "string", "format": "date" },
    "effectiveTo": { "type": ["string", "null"], "format": "date" },
    "sourceNote": { "type": ["string", "null"], "maxLength": 500 }
  },
  "additionalProperties": false
}
