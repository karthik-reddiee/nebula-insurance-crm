{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nebula.local/schemas/communication-event-create-request.schema.json",
  "title": "CommunicationEventCreateRequest",
  "type": "object",
  "required": ["type", "summary", "occurredAt", "links"],
  "properties": {
    "type": { "type": "string", "enum": ["Note", "Call", "Meeting", "EmailReference"] },
    "direction": { "type": ["string", "null"], "enum": ["Inbound", "Outbound", "Internal", null] },
    "summary": { "type": "string", "minLength": 1, "maxLength": 255 },
    "body": { "type": ["string", "null"], "maxLength": 8000 },
    "occurredAt": { "type": "string", "format": "date-time" },
    "emailReference": {
      "type": ["object", "null"],
      "properties": {
        "provider": { "type": ["string", "null"], "maxLength": 80 },
        "messageId": { "type": ["string", "null"], "maxLength": 255 },
        "subject": { "type": ["string", "null"], "maxLength": 255 },
        "sentAt": { "type": ["string", "null"], "format": "date-time" }
      },
      "additionalProperties": false
    },
    "participants": {
      "type": "array",
      "items": { "$ref": "communication-event.schema.json#/definitions/participant" },
      "default": []
    },
    "links": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "communication-event.schema.json#/definitions/link" }
    }
  },
  "additionalProperties": false
}
