{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nebula.local/schemas/submission.schema.json",
  "title": "Submission",
  "description": "Submission detail response contract (F0006-S0003). Includes denormalized linked entity context and completeness evaluation.",
  "type": "object",
  "required": [
    "id",
    "accountId",
    "brokerId",
    "currentStatus",
    "effectiveDate",
    "lobAttributes",
    "assignedToUserId",
    "rowVersion",
    "createdAt",
    "createdByUserId",
    "updatedAt",
    "updatedByUserId",
    "completeness"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "accountId": {
      "type": "string",
      "format": "uuid"
    },
    "brokerId": {
      "type": "string",
      "format": "uuid"
    },
    "programId": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "lineOfBusiness": {
      "type": ["string", "null"],
      "maxLength": 50
    },
    "lobAttributes": {
      "$ref": "https://nebula.local/schemas/lob-attribute-envelope.schema.json",
      "description": "Schema-pinned dynamic product attributes for this submission."
    },
    "currentStatus": {
      "type": "string",
      "enum": ["Received", "Triaging", "WaitingOnBroker", "ReadyForUWReview", "InReview", "Quoted", "BindRequested", "Bound", "Declined", "Withdrawn"]
    },
    "effectiveDate": {
      "type": "string",
      "format": "date"
    },
    "expirationDate": {
      "type": ["string", "null"],
      "format": "date"
    },
    "premiumEstimate": {
      "type": ["number", "null"],
      "minimum": 0
    },
    "description": {
      "type": ["string", "null"],
      "maxLength": 2000
    },
    "assignedToUserId": {
      "type": "string",
      "format": "uuid"
    },
    "accountName": {
      "type": "string",
      "description": "Denormalized from Account"
    },
    "accountRegion": {
      "type": ["string", "null"],
      "description": "Denormalized from Account"
    },
    "accountIndustry": {
      "type": ["string", "null"],
      "description": "Denormalized from Account"
    },
    "brokerName": {
      "type": "string",
      "description": "Denormalized from Broker"
    },
    "brokerLicenseNumber": {
      "type": ["string", "null"],
      "description": "Denormalized from Broker"
    },
    "programName": {
      "type": ["string", "null"],
      "description": "Denormalized from Program (nullable)"
    },
    "assignedToDisplayName": {
      "type": ["string", "null"],
      "description": "Denormalized from UserProfile"
    },
    "isStale": {
      "type": "boolean",
      "description": "Whether submission exceeds stale threshold for its current state"
    },
    "completeness": {
      "$ref": "https://nebula.local/schemas/submission-completeness.schema.json"
    },
    "availableTransitions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Valid next states for the authenticated user based on current state and role"
    },
    "rowVersion": {
      "type": "string",
      "description": "Opaque optimistic concurrency token. Echo this value in the If-Match header for update, assignment, and transition requests."
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByUserId": {
      "type": "string",
      "format": "uuid"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedByUserId": {
      "type": "string",
      "format": "uuid"
    }
  },
  "additionalProperties": false
}
