{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nebula.local/schemas/communication-event-follow-up-request.schema.json",
  "title": "CommunicationEventFollowUpRequest",
  "type": "object",
  "required": ["title", "assignedToUserId", "linkedEntityType", "linkedEntityId"],
  "properties": {
    "title": { "type": "string", "minLength": 1, "maxLength": 255 },
    "description": { "type": ["string", "null"], "maxLength": 2000 },
    "priority": { "type": "string", "enum": ["Low", "Normal", "High", "Urgent"], "default": "Normal" },
    "dueDate": { "type": ["string", "null"], "format": "date" },
    "assignedToUserId": { "type": "string", "format": "uuid" },
    "linkedEntityType": { "type": "string", "enum": ["Broker", "Account", "Submission", "Policy", "Renewal", "Task"] },
    "linkedEntityId": { "type": "string", "format": "uuid" }
  },
  "additionalProperties": false
}
