{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nebula.local/schemas/communication-event-correction-request.schema.json",
  "title": "CommunicationEventCorrectionRequest",
  "type": "object",
  "required": ["action", "reason"],
  "properties": {
    "action": { "type": "string", "enum": ["Correct", "Redact"] },
    "reason": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "summary": { "type": ["string", "null"], "maxLength": 255 },
    "body": { "type": ["string", "null"], "maxLength": 8000 },
    "links": {
      "type": ["array", "null"],
      "items": { "$ref": "communication-event.schema.json#/definitions/link" }
    },
    "participants": {
      "type": ["array", "null"],
      "items": { "$ref": "communication-event.schema.json#/definitions/participant" }
    }
  },
  "additionalProperties": false
}
