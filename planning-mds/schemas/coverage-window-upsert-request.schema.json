{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nebula.local/schemas/coverage-window-upsert-request.schema.json",
  "title": "CoverageWindowUpsertRequest",
  "description": "Create or update an explicit coverage window.",
  "type": "object",
  "required": ["coveredUserId", "backupUserId", "startsAt", "endsAt", "status"],
  "properties": {
    "coveredUserId": { "type": "string", "format": "uuid" },
    "backupUserId": { "type": "string", "format": "uuid" },
    "workQueueId": { "type": ["string", "null"], "format": "uuid" },
    "startsAt": { "type": "string", "format": "date-time" },
    "endsAt": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["Active", "Cancelled"] },
    "reason": { "type": ["string", "null"], "maxLength": 500 }
  },
  "additionalProperties": false
}
