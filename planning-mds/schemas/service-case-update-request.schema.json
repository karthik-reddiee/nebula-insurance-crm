{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nebula.local/schemas/service-case-update-request.schema.json",
  "title": "ServiceCaseUpdateRequest",
  "type": "object",
  "properties": {
    "summary": { "type": ["string", "null"], "minLength": 1, "maxLength": 255 },
    "description": { "type": ["string", "null"], "maxLength": 4000 },
    "priority": { "type": ["string", "null"], "enum": ["Low", "Medium", "High", "Urgent", null] },
    "ownerUserId": { "type": ["string", "null"], "format": "uuid" },
    "dueDate": { "type": ["string", "null"], "format": "date" },
    "followUpSummary": { "type": ["string", "null"], "maxLength": 1000 },
    "resolutionSummary": { "type": ["string", "null"], "maxLength": 1000 },
    "rowVersion": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
